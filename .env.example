# ============================================================
# CareCircle — Variables d'environnement
# Copiez ce fichier en .env.local pour le développement local
# Configurez ces variables dans Vercel pour la production
# ============================================================

# ─── Base de données PostgreSQL (Neon) ──────────────────────
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
# Obtenir sur: https://console.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/carecircle?sslmode=require"

# ─── NextAuth ────────────────────────────────────────────────
# URL publique de l'application (sans slash final)
NEXTAUTH_URL="http://localhost:3000"

# Clé secrète pour les JWT (générer avec: openssl rand -base64 32)
NEXTAUTH_SECRET="votre-secret-aleatoire-tres-long-ici"

# ─── Google OAuth (optionnel) ────────────────────────────────
# Obtenir sur: https://console.cloud.google.com/apis/credentials
# Ajouter les URIs autorisés: https://votre-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Stripe (paiements) ──────────────────────────────────────
# Obtenir sur: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# IDs des tarifs Stripe (créer dans le Dashboard Stripe)
# Plan Premium: 9.99€/mois
STRIPE_PREMIUM_PRICE_ID="price_..."
# Plan Famille: 19.99€/mois
STRIPE_FAMILY_PRICE_ID="price_..."

# ─── URL publique ────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ─── Flutterwave (paiements Afrique — optionnel) ─────────────
# Obtenir sur: https://dashboard.flutterwave.com/
FLUTTERWAVE_PUBLIC_KEY=""
FLUTTERWAVE_SECRET_KEY=""
FLUTTERWAVE_ENCRYPTION_KEY=""
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=""
